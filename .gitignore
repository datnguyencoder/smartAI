# SmartMart AI — monorepo (root)
# Per-package rules also exist: backend/, frontend/, ai-service/

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Environment & secrets ---
.env
.env.*
!.env.example
!**/.env.example
!**/.env.ngrok.example
docker/.env

# --- Logs & temp ---
*.log
logs/
*.tmp
*.swp
*~
.cache/

# --- CodeGraph (local index) ---
.codegraph/

# --- IDE ---
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.vscode/*
!.vscode/settings.json

# --- Node / frontend ---
node_modules/
dist/
*.tsbuildinfo
frontend/node_modules/
frontend/dist/
frontend/qa/

# --- Java / backend ---
target/
backend/target/
*.class
*.jar
!backend/.mvn/wrapper/maven-wrapper.jar

# --- Python / ai-service ---
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
ai-service/.venv/
ai-service/__pycache__/
ai-service/datasets/raw/online-retail-dataset.csv
ai-service/datasets/processed/uci_online_retail_daily.csv

# --- ML artifacts (regenerated locally; keep .gitkeep) ---
ai-service/app/saved_models/*.joblib
!ai-service/app/saved_models/.gitkeep

# --- ngrok local run (scripts/ngrok-setup.sh) ---
.ngrok-run/

# --- Cursor (local agent plans; team rules under .cursor/rules stay tracked) ---
.cursor/plans/

# --- Test / build output ---
coverage/
test-results/
*.hprof

# --- Documentation ---
docs/doc_threads_backend/
