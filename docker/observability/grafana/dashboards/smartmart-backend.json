{
  "title": "SmartMart Backend — Overview",
  "uid": "smartmart-backend-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"smartmart-backend\"}[1m])) by (uri, status)",
          "legendFormat": "{{uri}} [{{status}}]"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP p95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"smartmart-backend\"}[5m])) by (le, uri))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "5xx Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"smartmart-backend\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM Heap Used / Max",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"smartmart-backend\", area=\"heap\"})",
          "legendFormat": "used"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{application=\"smartmart-backend\", area=\"heap\"})",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 5,
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"smartmart-backend\"}",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "id": 6,
      "title": "HikariCP Active / Max Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"smartmart-backend\"}",
          "legendFormat": "active"
        },
        {
          "expr": "hikaricp_connections_max{application=\"smartmart-backend\"}",
          "legendFormat": "max"
        }
      ]
    }
  ]
}
