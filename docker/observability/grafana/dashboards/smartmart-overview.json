{
  "title": "SmartMart — System Overview",
  "uid": "smartmart-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["smartmart"],
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Backend Status",
      "gridPos": { "x": 0, "y": 0, "w": 3, "h": 4 },
      "targets": [{ "expr": "up{job=\"smartmart_backend\"}", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 2, "type": "stat", "title": "AI Service Status",
      "gridPos": { "x": 3, "y": 0, "w": 3, "h": 4 },
      "targets": [{ "expr": "up{job=\"smartmart_ai_service\"}", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 3, "type": "stat", "title": "PostgreSQL",
      "gridPos": { "x": 6, "y": 0, "w": 3, "h": 4 },
      "targets": [{ "expr": "up{job=\"postgres\"}", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 4, "type": "stat", "title": "Redis",
      "gridPos": { "x": 9, "y": 0, "w": 3, "h": 4 },
      "targets": [{ "expr": "up{job=\"redis\"}", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 5, "type": "stat", "title": "VPS RAM Used %",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "id": 6, "type": "stat", "title": "VPS CPU Used %",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 7, "type": "stat", "title": "Disk Used %",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "id": 8, "type": "timeseries", "title": "HTTP Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"smartmart_backend\",status=~\"2..\"}[1m]))", "legendFormat": "2xx OK", "refId": "A" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"smartmart_backend\",status=~\"4..\"}[1m]))", "legendFormat": "4xx Client Error", "refId": "B" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"smartmart_backend\",status=~\"5..\"}[1m]))", "legendFormat": "5xx Server Error", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 9, "type": "timeseries", "title": "HTTP Latency P50/P95/P99",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"smartmart_backend\"}[5m])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"smartmart_backend\"}[5m])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"smartmart_backend\"}[5m])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 10, "type": "timeseries", "title": "JVM Memory — Heap Used",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"smartmart_backend\"}", "legendFormat": "Heap Used", "refId": "A" },
        { "expr": "jvm_memory_max_bytes{area=\"heap\",job=\"smartmart_backend\"}", "legendFormat": "Heap Max", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "VPS RAM (Available vs Total)",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 8 },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes", "legendFormat": "Total", "refId": "A" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 12, "type": "timeseries", "title": "VPS CPU Usage %",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "targets": [
        { "expr": "100 - (avg by(cpu) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU {{cpu}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 13, "type": "timeseries", "title": "JVM Threads",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
      "targets": [
        { "expr": "jvm_threads_live_threads{job=\"smartmart_backend\"}", "legendFormat": "Live", "refId": "A" },
        { "expr": "jvm_threads_daemon_threads{job=\"smartmart_backend\"}", "legendFormat": "Daemon", "refId": "B" }
      ]
    },
    {
      "id": 14, "type": "timeseries", "title": "Redis Memory Used",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "Used", "refId": "A" },
        { "expr": "redis_memory_max_bytes", "legendFormat": "Max", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 15, "type": "timeseries", "title": "PostgreSQL Active Connections",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 6 },
      "targets": [
        { "expr": "pg_stat_activity_count{datname=\"smartmart_db\"}", "legendFormat": "Active", "refId": "A" }
      ]
    }
  ]
}
