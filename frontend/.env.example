# SmartMart Frontend — biến môi trường Vite
#
# Local dev:
#   cp .env.example .env
#   npm run dev
#
# Ngrok (tunnel backend):
#   cp .env.ngrok.example .env
#   # sửa URL backend ngrok
#
# Docker full stack: VITE_API_BASE_URL trong docker/.env (build/run frontend container)
#
# Chỉ biến prefix VITE_ được expose ra browser.

# Backend REST API (Spring Boot) - khong them slash cuoi
VITE_API_BASE_URL=http://localhost:8080

# Production (Vercel):
# VITE_API_BASE_URL=https://api.datnguyencoder.asia
