{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "framework": "vite",
  "git": {
    "deploymentEnabled": false
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.datnguyencoder.asia/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://api.datnguyencoder.asia/media/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
