{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.datnguyencoder.asia/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://api.datnguyencoder.asia/media/:path*"
    }
  ]
}
