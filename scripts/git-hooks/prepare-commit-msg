#!/bin/sh
# Strips Cursor co-author / attribution lines from commit messages.
# Install: ./scripts/git-hooks/install.sh

COMMIT_MSG_FILE="$1"
if [ -f "$COMMIT_MSG_FILE" ]; then
  sed -i.bak '/cursoragent@cursor\.com/d' "$COMMIT_MSG_FILE" 2>/dev/null \
    || sed -i '' '/cursoragent@cursor\.com/d' "$COMMIT_MSG_FILE" 2>/dev/null \
    || sed -i '/cursoragent@cursor\.com/d' "$COMMIT_MSG_FILE"
  sed -i.bak '/Made-with: Cursor/d' "$COMMIT_MSG_FILE" 2>/dev/null \
    || sed -i '' '/Made-with: Cursor/d' "$COMMIT_MSG_FILE" 2>/dev/null \
    || sed -i '/Made-with: Cursor/d' "$COMMIT_MSG_FILE"
  rm -f "${COMMIT_MSG_FILE}.bak"
fi
